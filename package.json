{
  "name": "oxc-config-hope",
  "version": "0.3.5",
  "description": "Personal configuration for oxc.",
  "keywords": [
    "eslint",
    "oxc",
    "oxfmt",
    "oxlint",
    "prettier",
    "typescript"
  ],
  "license": "ISC",
  "author": {
    "name": "Mister-Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "url": "https://github.com/Mister-Hope/oxc-config-hope"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./oxfmt": {
      "types": "./dist/oxfmt.d.ts",
      "default": "./dist/oxfmt.js"
    },
    "./oxlint": {
      "types": "./dist/oxlint.d.ts",
      "default": "./dist/oxlint.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "pnpm lint:oxlint --fix && oxfmt .",
    "lint:check": "pnpm lint:oxlint && oxfmt --check .",
    "lint:oxlint": "oxlint --report-unused-disable-directives --deny-warnings",
    "prepublish": "pnpm build",
    "test": "vitest"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.4",
    "publint": "0.3.21",
    "tsdown": "0.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "oxfmt": ">=0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": ">=0.22.1"
  },
  "peerDependenciesMeta": {
    "oxfmt": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.1",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
