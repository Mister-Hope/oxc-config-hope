{
  "name": "oxc-config-hope",
  "version": "0.0.7",
  "description": "Personal configuration for oxc.",
  "keywords": [
    "eslint",
    "oxc",
    "oxfmt",
    "oxlint",
    "prettier",
    "typescript"
  ],
  "license": "ISC",
  "author": {
    "name": "Mister-Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "url": "https://github.com/Mister-Hope/oxc-config-hope"
  },
  "files": [
    "dist",
    ".oxfmtrc.json"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "pnpm lint:oxlint --fix && oxfmt .",
    "lint:check": "pnpm lint:oxlint && oxfmt --check .",
    "lint:oxlint": "oxlint --report-unused-disable-directives --deny-warnings",
    "prepublish": "pnpm build"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.2",
    "tsdown": "0.21.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "oxfmt": ">=0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": ">=0.17.0"
  },
  "peerDependenciesMeta": {
    "oxfmt": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.32.1"
}
